<resources>
    <style name="AppTheme" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowBackground">@color/paper</item>
    </style>

    <style name="AppTheme.Dark" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/dark_ink</item>
        <item name="android:textColorSecondary">@color/dark_ink</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:statusBarColor">@color/dark_paper</item>
        <item name="android:navigationBarColor">@color/dark_paper</item>
        <item name="android:windowBackground">@color/dark_paper</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>
</resources>
